# Database
VITE_DATABASE_URL=mysql://root:password@localhost:3306/vebtask

# Better Auth
BETTER_AUTH_SECRET=your-super-secret-key-here
VITE_APP_URL=http://localhost:5173

# OpenAI Configuration (for Whisper API)
OPENAI_API_KEY=your_openai_api_key_placeholder

# Optional: OpenRouter (alternative AI provider)  
OPENROUTER_API_KEY=your_openrouter_key_placeholder

# Fireflies.ai integration (meeting summaries → notification bell)
FIREFLIES_API_KEY=your_fireflies_api_key_here

# Email / SMTP — using Resend (resend.com)
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=re_xxxxxxxxxxxxxxxxxxxx
SMTP_FROM="VebTask <noreply@yourdomain.com>"

# Production settings
NODE_ENV=production
BETTER_AUTH_URL=https://vebtask.com